{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Polly": "Warning"
    }
  },
  "AllowedHosts": "*",
  "HackerNews": {
    "BaseUrl": "https://hacker-news.firebaseio.com/v0/",
    "HttpTimeoutSeconds": 10,
    "MaxStories": 200,
    "IdListCacheSeconds": 60,
    "ItemCacheMinutes": 10,
    "FetchConcurrency": 10,
    "CacheWarmIntervalSeconds": 60,
    "WarmTopN": 200,
    "EnableCacheWarmer": true
  }
}
